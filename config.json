{
  "schemaVersion": 2,
  "horizonYears": 4,
  "cadenceLabel": "Updated weekly",
  "historyWeeks": 104,
  "sigmoid": { "center": 70.0, "scale": 10.0, "floor": 0.05, "span": 0.40 },

  "factors": {
    "polarization": { "weight": 0.20, "method": "curated" },
    "distrust":     { "weight": 0.15, "method": "curated" },
    "violence":     { "weight": 0.20, "method": "live", "source": "gdelt" },
    "economy":      { "weight": 0.10, "method": "live", "source": "fred"  },
